get_ipython().getoutput("pip install ultralytics -q")


import os
import cv2
import torch
import numpy as np
import pandas as pd
import torch.nn as nn
import torchvision.transforms as transforms
import matplotlib.pyplot as plt

from PIL import Image
from ultralytics import YOLO
from torchvision import models
from torch.utils.data import Dataset, DataLoader
from sklearn.metrics import classification_report


train_df = pd.read_csv("/kaggle/input/datasets/avins2005/leaf-deficiency/Coffee Nutrient Deficiency/train_data.csv")
valid_df = pd.read_csv("/kaggle/input/datasets/avins2005/leaf-deficiency/Coffee Nutrient Deficiency/valid_data.csv")


label_map = {
    "Healthy":0,
    "Early Deficiency":1,
    "Critical Deficiency":2
}

class_names = ["Healthy","Early Deficiency","Critical Deficiency"]


transform = transforms.Compose([
    transforms.Resize((300,300)),
    transforms.RandomHorizontalFlip(),
    transforms.RandomRotation(10),
    transforms.ToTensor(),
    transforms.Normalize(
        mean=[0.485,0.456,0.406],
        std=[0.229,0.224,0.225]
    )
])


class ImageDataset(Dataset):

    def __init__(self, dataframe, img_dir, transform=None):
        self.df = dataframe
        self.img_dir = img_dir
        self.transform = transform

    def __len__(self):
        return len(self.df)

    def __getitem__(self, idx):

        row = self.df.iloc[idx]

        img_path = os.path.join(
            self.img_dir,
            row["Label"],
            "images",
            row["Image_Name"]
        )

        image = Image.open(img_path).convert("RGB")

        if self.transform:
            image = self.transform(image)

        label = torch.tensor(label_map[row["Label"]])

        return image, label   # ✅ ONLY 2 VALUES


train_dataset = ImageDataset(
    train_df,
    "/kaggle/input/datasets/avins2005/leaf-deficiency/Coffee Nutrient Deficiency/train",
    transform
)

valid_dataset = ImageDataset(
    valid_df,
    "/kaggle/input/datasets/avins2005/leaf-deficiency/Coffee Nutrient Deficiency/valid",
    transform
)

train_loader = DataLoader(train_dataset, batch_size=32, shuffle=True)
valid_loader = DataLoader(valid_dataset, batch_size=32)


class ImageModel(nn.Module):

    def __init__(self):
        super().__init__()

        self.model = models.efficientnet_b3(weights="IMAGENET1K_V1")

        self.model.classifier = nn.Sequential(
            nn.Linear(1536,128),
            nn.ReLU(),
            nn.Dropout(0.4),
            nn.Linear(128,3)
        )

    def forward(self, x):
        return self.model(x)


device = torch.device("cuda" if torch.cuda.is_available() else "cpu")

model = ImageModel().to(device)

criterion = nn.CrossEntropyLoss()
optimizer = torch.optim.Adam(model.parameters(), lr=1e-4)


for epoch in range(40):

    model.train()
    total_loss = 0

    for images, labels in train_loader:

        images = images.to(device)
        labels = labels.to(device)

        optimizer.zero_grad()

        outputs = model(images)
        loss = criterion(outputs, labels)

        loss.backward()
        optimizer.step()

        total_loss += loss.item()

    print(f"Epoch {epoch+1} Loss: {total_loss/len(train_loader):.4f}")


model.eval()

all_preds = []
all_labels = []

with torch.no_grad():

    for images, labels in valid_loader:

        images = images.to(device)

        outputs = model(images)
        _, preds = torch.max(outputs, 1)

        all_preds.extend(preds.cpu().numpy())
        all_labels.extend(labels.numpy())

print(classification_report(all_labels, all_preds))


torch.save(model.state_dict(), "/kaggle/working/image_model.pth")


yolo_model = YOLO("yolov8n.pt")


def predict_with_detection(image_path):

    model.eval()

    img = cv2.imread(image_path)
    img = cv2.cvtColor(img, cv2.COLOR_BGR2RGB)

    results = yolo_model(img)

    if results[0].boxes is not None:
        boxes = results[0].boxes.xyxy.cpu().numpy()
        scores = results[0].boxes.conf.cpu().numpy()
    else:
        boxes, scores = [], []

    if len(boxes) > 0:
        best = np.argmax(scores)
        x1,y1,x2,y2 = boxes[best].astype(int)
        crop = img[y1:y2, x1:x2]
    else:
        crop = img

    pil_img = Image.fromarray(crop)
    image_tensor = transform(pil_img).unsqueeze(0).to(device)

    with torch.no_grad():
        outputs = model(image_tensor)   # ✅ FIXED
        probs = torch.softmax(outputs, dim=1)
        conf, pred = torch.max(probs, 1)

    label = class_names[pred.item()]
    confidence = conf.item() * 100

    print(f"Prediction: {label} ({confidence:.2f}%)")

    plt.imshow(img)
    plt.axis("off")
    plt.show()

    return label, confidence


image_path = "/kaggle/input/datasets/avins2005/leaf-deficiency/Coffee Nutrient Deficiency/test/Healthy/images/Healthy-67-_jpg.rf.188b30367a777fe7c308f33926d72a7d.jpg"

predict_with_detection(image_path)


