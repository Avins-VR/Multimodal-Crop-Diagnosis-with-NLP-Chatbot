get_ipython().getoutput("pip install ultralytics -q")


import os
import cv2
import torch
import joblib
import numpy as np
import pandas as pd
import torch.nn as nn
import torchvision.transforms as transforms
import matplotlib.pyplot as plt

from PIL import Image
from ultralytics import YOLO
from sklearn.preprocessing import StandardScaler
from sklearn.metrics import classification_report

from torchvision import models
from torch.utils.data import Dataset, DataLoader


os.listdir("/kaggle/input/datasets/avins2005/leaf-deficiency/Coffee Nutrient Deficiency")


train_df = pd.read_csv("/kaggle/input/datasets/avins2005/leaf-deficiency/Coffee Nutrient Deficiency/train_data.csv")
valid_df = pd.read_csv("/kaggle/input/datasets/avins2005/leaf-deficiency/Coffee Nutrient Deficiency/valid_data.csv")
test_df  = pd.read_csv("/kaggle/input/datasets/avins2005/leaf-deficiency/Coffee Nutrient Deficiency/test_data.csv")


features = [
'N','P','K','ph','soil_moisture',
'temperature','humidity','rainfall','sunlight_exposure'
]


scaler = StandardScaler()

train_df[features] = scaler.fit_transform(train_df[features])
valid_df[features] = scaler.transform(valid_df[features])
test_df[features]  = scaler.transform(test_df[features])

joblib.dump(scaler, "/kaggle/working/scaler.pkl")


transform = transforms.Compose([
    transforms.Resize((224,224)),
    transforms.ToTensor()
])


class MultimodalDataset(Dataset):

    def __init__(self, dataframe, img_dir, transform=None):

        self.df = dataframe
        self.img_dir = img_dir
        self.transform = transform

        self.label_map = {
            "Healthy":0,
            "Early Deficiency":1,
            "Critical Deficiency":2
        }

    def __len__(self):
        return len(self.df)

    def __getitem__(self, idx):

        row = self.df.iloc[idx]

        img_path = os.path.join(
            self.img_dir,
            row["Label"],
            "images",
            row["Image_Name"]
        )

        image = Image.open(img_path).convert("RGB")

        if self.transform:
            image = self.transform(image)

        tabular = torch.tensor(
            row[features].values.astype(np.float32)
        )

        label = torch.tensor(self.label_map[row["Label"]])

        return image, tabular, label


train_dataset = MultimodalDataset(
    train_df,
    "/kaggle/input/datasets/avins2005/leaf-deficiency/Coffee Nutrient Deficiency/train",
    transform
)

valid_dataset = MultimodalDataset(
    valid_df,
    "/kaggle/input/datasets/avins2005/leaf-deficiency/Coffee Nutrient Deficiency/valid",
    transform
)

train_loader = DataLoader(train_dataset,batch_size=32,shuffle=True)
valid_loader = DataLoader(valid_dataset,batch_size=32)


class EarlyFusionModel(nn.Module):

    def __init__(self,num_tabular_features):

        super().__init__()

        self.cnn = models.efficientnet_b3(pretrained=True)
        self.cnn.classifier = nn.Identity()

        self.tabular_net = nn.Sequential(
            nn.Linear(num_tabular_features,64),
            nn.ReLU(),
            nn.Linear(64,32),
            nn.ReLU()
        )

        self.classifier = nn.Sequential(
            nn.Linear(1536+32,128),
            nn.ReLU(),
            nn.Dropout(0.3),
            nn.Linear(128,3)
        )

    def forward(self,image,tabular):

        img_feat = self.cnn(image)
        tab_feat = self.tabular_net(tabular)

        fused = torch.cat((img_feat,tab_feat),dim=1)

        return self.classifier(fused)


device = torch.device("cuda" if torch.cuda.is_available() else "cpu")

model = EarlyFusionModel(len(features)).to(device)

criterion = nn.CrossEntropyLoss()

optimizer = torch.optim.Adam(model.parameters(),lr=1e-4)


for epoch in range(100):

    model.train()
    total_loss = 0

    for images,tabular,labels in train_loader:

        images = images.to(device)
        tabular = tabular.to(device)
        labels = labels.to(device)

        optimizer.zero_grad()

        outputs = model(images,tabular)

        loss = criterion(outputs,labels)

        loss.backward()
        optimizer.step()

        total_loss += loss.item()

    print(f"Epoch {epoch+1} Loss:{total_loss/len(train_loader)}")


model.eval()

all_preds = []
all_labels = []

with torch.no_grad():

    for images,tabular,labels in valid_loader:

        images = images.to(device)
        tabular = tabular.to(device)

        outputs = model(images,tabular)

        _,preds = torch.max(outputs,1)

        all_preds.extend(preds.cpu().numpy())
        all_labels.extend(labels.numpy())

print(classification_report(all_labels,all_preds))


torch.save(model.state_dict(),"/kaggle/working/model.pth")


yolo_model = YOLO("yolov8n.pt")


class_names = [
"Healthy",
"Early Deficiency",
"Critical Deficiency"
]


def predict_with_detection(image_path,**kwargs):

    model.eval()

    img = cv2.imread(image_path)
    img_rgb = cv2.cvtColor(img,cv2.COLOR_BGR2RGB)

    results = yolo_model(img_rgb)

    boxes = results[0].boxes.xyxy.cpu().numpy()
    scores = results[0].boxes.conf.cpu().numpy()

    detected_crop = img_rgb

    for box,score in zip(boxes,scores):

        if score < 0.4:
            continue

        x1,y1,x2,y2 = box.astype(int)

        cv2.rectangle(
            img_rgb,
            (x1,y1),
            (x2,y2),
            (255,255,0),
            3
        )

        detected_crop = img_rgb[y1:y2,x1:x2]

    crop_pil = Image.fromarray(detected_crop)

    image_tensor = transform(crop_pil).unsqueeze(0).to(device)

    feature_values = np.array([[kwargs[f] for f in features]])

    feature_values = scaler.transform(feature_values)

    tabular = torch.tensor(feature_values,dtype=torch.float32).to(device)

    with torch.no_grad():

        outputs = model(image_tensor,tabular)

        probs = torch.softmax(outputs,dim=1)

        confidence,predicted = torch.max(probs,1)

    label = class_names[predicted.item()]
    conf = confidence.item()*100

    cv2.putText(
        img_rgb,
        f"{label} ({conf:.2f}%)",
        (30,50),
        cv2.FONT_HERSHEY_SIMPLEX,
        1,
        (0,255,0),
        3
    )

    plt.figure(figsize=(8,8))
    plt.imshow(img_rgb)
    plt.axis("off")
    plt.show()

    return label,conf


image_path = "/kaggle/input/datasets/avins2005/leaf-deficiency/Coffee Nutrient Deficiency/test/Healthy/images/Healthy-5-_016_jpg.rf.b350ca92c99721ccc28d29a3fd21a4dd.jpg"

predict_with_detection(
    image_path,
    N=7,
    P=15,
    K=1,
    ph=4.53,
    soil_moisture=6.94,
    temperature=11.8,
    humidity=16.91,
    rainfall=10.44,
    sunlight_exposure=4.54
)



